DATABASE_URL="postgresql://postgres:password@localhost:5432/cybersuite"
JWT_ACCESS_SECRET="change_me_access_secret_very_long_random_string"
JWT_REFRESH_SECRET="change_me_refresh_secret_very_long_random_string"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
BCRYPT_SALT_ROUNDS=12
PORT=5000
CLIENT_URL="http://localhost:3000"
NODE_ENV="development"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# HaveIBeenPwned API
HIBP_API_KEY="your_hibp_api_key"
HIBP_API_URL="https://haveibeenpwned.com/api/v3"
