generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String               @id @default(uuid())
  email                       String               @unique
  name                        String
  passwordHash                String
  isVerified                  Boolean              @default(false)
  twoFASecret                 String?
  twoFAEnabled                Boolean              @default(false)
  role                        Role                 @default(USER)
  publicKey                   String?
  encPrivateKey               String?
  avatar                      String?
  bio                         String?
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  verificationCode            String?
  verificationExpires         DateTime?
  masterPasswordHash          String?
  masterPasswordSalt          String?
  recoveryKeyHash             String?
  resetToken                  String?
  resetTokenExpires           DateTime?
  notifyApp                   Boolean              @default(true)
  notifyEmail                 Boolean              @default(true)
  notifySMS                   Boolean              @default(false)
  notifyWhatsApp              Boolean              @default(false)
  phoneNumber                 String?
  allergies                   String?
  bloodGroup                  String?
  chronicConditions           String?
  emergencyContacts           String?
  isActive                    Boolean              @default(true)
  lastActiveAt                DateTime             @default(now())
  legacyInactivityDays        Int                  @default(180)
  allowedCountries            String[]             @default(["*"])
  riskLevel                   String               @default("LOW")
  activityLogs                ActivityLog[]
  adminActions                AdminAction[]
  alerts                      Alert[]
  asProfessionalConsultations Consultation[]       @relation("ProfessionalConsultations")
  consultations               Consultation[]       @relation("UserConsultations")
  contracts                   Contract[]
  doctorAccesses              DoctorAccess[]
  expenses                    Expense[]
  fileRecords                 FileRecord[]
  ownedGroups                 Group[]              @relation("GroupOwner")
  groups                      GroupMember[]
  incidents                   Incident[]
  medicalRecords              MedicalRecord[]      @relation("PatientRecords")
  receivedMessages            Message[]            @relation("ReceivedMessages")
  sentMessages                Message[]            @relation("SentMessages")
  notifications               Notification[]
  professionalProfile         ProfessionalProfile?
  recoveryBackups             RecoveryBackup[]
  reminders                   Reminder[]
  reviews                     Review[]
  sessions                    Session[]
  subscriptions               Subscription[]
  trustedContacts             TrustedContact[]
  vaultEntries                VaultEntry[]
  warranties                  Warranty[]
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  deviceInfo   String
  ipAddress    String
  userAgent    String   @default("")
  refreshToken String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @default(now())
  deviceId     String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id               String    @id @default(uuid())
  senderId         String
  receiverId       String
  encryptedMessage String
  encryptedKey     String
  iv               String
  status           MsgStatus @default(SENT)
  selfDestruct     Boolean   @default(false)
  destructAt       DateTime?
  fileUrl          String?
  fileName         String?
  fileType         String?
  createdAt        DateTime  @default(now())
  receiver         User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender           User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}

model VaultEntry {
  id            String   @id @default(uuid())
  userId        String
  encryptedData String
  category      String   @default("general")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  strength      Int      @default(0)
  groupId       String?
  group         Group?   @relation(fields: [groupId], references: [id])
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Warranty {
  id           String   @id @default(uuid())
  userId       String
  productName  String
  price        Float    @default(0)
  purchaseDate DateTime
  expiryDate   DateTime
  encFileUrl   String?
  notes        String?
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedicalRecord {
  id              String          @id @default(uuid())
  patientId       String
  fileName        String
  encFileUrl      String
  encKeyForOwner  String
  description     String?
  recordDate      DateTime        @default(now())
  createdAt       DateTime        @default(now())
  doctorAccesses  DoctorAccess[]
  patient         User            @relation("PatientRecords", fields: [patientId], references: [id], onDelete: Cascade)
  oneTimeAccesses OneTimeAccess[]
}

model DoctorAccess {
  id        String        @id @default(uuid())
  recordId  String
  doctorId  String
  encKey    String
  expiresAt DateTime
  grantedAt DateTime      @default(now())
  doctor    User          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  record    MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

model OneTimeAccess {
  id        String        @id @default(uuid())
  recordId  String
  token     String        @unique
  encKey    String
  expiresAt DateTime
  createdAt DateTime      @default(now())
  record    MedicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  metadata  Json?
  status    String   @default("SUCCESS")
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  metadata  Json?
  priority  Priority @default(MEDIUM)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  remindAt    DateTime
  category    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FileRecord {
  id             String   @id @default(uuid())
  userId         String
  category       String
  fileName       String
  fileSize       Int
  mimeType       String
  storagePath    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  blockchainHash String?
  blockchainTxId String?
  groupId        String?
  group          Group?   @relation(fields: [groupId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String   @id @default(uuid())
  userId       String
  name         String
  category     String
  amount       Float
  currency     String   @default("USD")
  billingCycle String
  nextBilling  DateTime
  isAutoRenew  Boolean  @default(true)
  remindMe     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrustedContact {
  id                String    @id @default(uuid())
  userId            String
  email             String
  name              String
  type              String    @default("LEGACY")
  accessGranted     Boolean   @default(false)
  accessRequestedAt DateTime?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  userId      String
  title       String
  amount      Float
  currency    String   @default("USD")
  category    String
  receiptUrl  String?
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecoveryBackup {
  id          String   @id @default(uuid())
  userId      String
  serviceName String
  backupCodes String
  notes       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contract {
  id            String    @id @default(uuid())
  userId        String
  title         String
  contentHash   String
  signatureHash String?
  signedAt      DateTime?
  status        String    @default("PENDING")
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Group {
  id           String        @id @default(uuid())
  name         String
  type         String
  ownerId      String
  createdAt    DateTime      @default(now())
  fileRecords  FileRecord[]
  owner        User          @relation("GroupOwner", fields: [ownerId], references: [id])
  members      GroupMember[]
  vaultEntries VaultEntry[]
}

model GroupMember {
  id      String @id @default(uuid())
  groupId String
  userId  String
  role    String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfessionalProfile {
  id             String             @id @default(uuid())
  userId         String             @unique
  type           String
  specialization String
  qualification  String
  experience     Int
  fee            Float
  bio            String?
  isVerified     Boolean            @default(false)
  licenseUrl     String?
  rating         Float              @default(0)
  availability   Json?
  createdAt      DateTime           @default(now())
  status         VerificationStatus @default(PENDING)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Incident {
  id          String   @id @default(uuid())
  title       String
  description String
  severity    Priority @default(MEDIUM)
  status      String   @default("OPEN")
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

model SecurityRule {
  id          String   @id @default(uuid())
  name        String
  description String
  trigger     String
  threshold   Int
  action      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Consultation {
  id             String                @id @default(uuid())
  userId         String
  professionalId String
  status         String                @default("PENDING")
  type           String                @default("CHAT")
  feePaid        Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  professional   User                  @relation("ProfessionalConsultations", fields: [professionalId], references: [id])
  user           User                  @relation("UserConsultations", fields: [userId], references: [id])
  messages       ConsultationMessage[]
}

model ConsultationMessage {
  id               String       @id @default(uuid())
  consultationId   String
  senderId         String
  encryptedContent String
  encryptedKey     String
  iv               String
  type             String       @default("TEXT")
  fileUrl          String?
  createdAt        DateTime     @default(now())
  consultation     Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
}

model Review {
  id             String   @id @default(uuid())
  userId         String
  professionalId String
  rating         Int
  comment        String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])
}

model Alert {
  id         String   @id @default(uuid())
  userId     String?
  type       String
  severity   Priority @default(MEDIUM)
  message    String
  ipAddress  String?
  location   String?
  deviceInfo String?
  metadata   Json?
  status     String   @default("NEW")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])
}

model AdminAction {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String?
  targetId   String?
  details    String
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

model Policy {
  id          String   @id @default(uuid())
  name        String
  description String
  type        String
  rules       Json
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String
  description String?
  isEnabled   Boolean  @default(false)
  rules       Json?
  updatedAt   DateTime @updatedAt
}

model SystemMetric {
  id        String   @id @default(uuid())
  type      String
  value     Float
  unit      String
  metadata  Json?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
  PATIENT
  DOCTOR
  MEDICAL
  PROFESSIONAL
  STUDENT
  ACADEMIC
  LAWYER
  HEALTHCARE_STAFF
  EMERGENCY_PROFILE
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum MsgStatus {
  SENT
  DELIVERED
  READ
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
